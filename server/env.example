# Database
DATABASE_URL="file:./dev.db"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Server Configuration
PORT=3003
NODE_ENV=development

# Client URL (for CORS and redirects)
CLIENT_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxx"
EMAIL_FROM="AdaptEd Russia <noreply@your-domain.com>"
EMAIL_REPLY_TO="support@your-domain.com"
EMAIL_REQUEST_TIMEOUT_MS=10000
EMAIL_MAX_RETRIES=2

# YooKassa Configuration
YOOKASSA_SHOP_ID="your-yookassa-shop-id"
YOOKASSA_SECRET_KEY="your-yookassa-secret-key"

# For testing, you can use YooKassa sandbox credentials
# Get them from: https://yookassa.ru/developers/using-api/testing

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# DeepSeek AI Configuration
# Получите API ключ на https://platform.deepseek.com/
DEEPSEEK_API_KEY="your-deepseek-api-key" 
